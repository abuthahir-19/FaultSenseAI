    </mxCell>

    <mxCell id="71"
      value="&lt;b&gt;① Alarm Retrieval&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;alarm_retrieval_agent.py&lt;/font&gt;&lt;br/&gt;Hybrid search · sets severity_escalated"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#be185d;fontColor=#831843;fontSize=10;shadow=1;"
      tooltip="Runs HybridRetriever(query, filters, top_k). Sets severity_escalated=True if any CRITICAL incident found. Writes retrieved_incidents to state."
      vertex="1" parent="70">
