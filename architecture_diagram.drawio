    </mxCell>

    <mxCell id="72"
      value="&lt;b&gt;② Cross-Correlation&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;Deterministic · no LLM&lt;/font&gt;&lt;br/&gt;Cluster by region + technology (6h window)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#be185d;fontColor=#831843;fontSize=10;shadow=1;"
      tooltip="Groups incidents by (network_region, technology_type) within 6-hour time windows. Computes dominant_vendor, max_severity, time_span_hours per cluster."
      vertex="1" parent="70">
      <mxGeometry x="155" y="133" width="258" height="62" as="geometry" />
    </mxCell>

    <mxCell id="73"
      value="&lt;b&gt;③ Root Cause Analysis&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;root_cause_agent.py · GPT-4o&lt;/font&gt;&lt;br/&gt;Grounded on incidents + cluster metadata"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#be185d;fontColor=#831843;fontSize=10;shadow=1;"
      tooltip="GPT-4o analyses correlation clusters and retrieved incidents. Produces root_cause string citing specific alarm IDs. Context-bound — cannot hallucinate data not retrieved."
      vertex="1" parent="70">
