    </mxCell>

    <mxCell id="61"
      value="&lt;b&gt;EmbeddingManager&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;embeddings.py&lt;/font&gt;&lt;br/&gt;text-embedding-3-small&lt;br/&gt;embed_texts_concurrent() · 3 workers · batch 512"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;fontColor=#14532d;fontSize=10;shadow=1;"
      tooltip="Wraps OpenAI embeddings. embed_texts_concurrent() uses ThreadPoolExecutor(max_workers=3, batch_size=512). Reduces ingest from ~50s to ~12-15s."
      vertex="1" parent="60">
      <mxGeometry x="25" y="55" width="385" height="85" as="geometry" />
    </mxCell>

    <mxCell id="62"
      value="&lt;b&gt;HybridRetriever&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;hybrid_retriever.py&lt;/font&gt;&lt;br/&gt;RRF score = Σ 1 / (60 + rank_i)&lt;br/&gt;23% better top-5 vs semantic-only"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;fontColor=#14532d;fontSize=10;shadow=1;"
      tooltip="Fuses ChromaDB and BM25 ranked lists via RRF (k=60). Documents in both lists receive additive score boost. Returns top-K by combined rrf_score."
      vertex="1" parent="60">
      <mxGeometry x="25" y="155" width="385" height="85" as="geometry" />
    </mxCell>

    <mxCell id="63"
      value="&lt;b&gt;ChromaDBStore&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;vectorstore.py&lt;/font&gt;&lt;br/&gt;Cosine similarity · HNSW index&lt;br/&gt;Metadata pre-filtering (where clause)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbf7d0;strokeColor=#15803d;fontColor=#14532d;fontSize=10;shadow=1;"
      tooltip="ChromaDB PersistentClient. similarity_search() with optional metadata filters: network_region, severity, device_vendor, technology_type."
      vertex="1" parent="60">
